---------------------------------------------------
-- PLAYER DEATH / RESET DETECTION
---------------------------------------------------

local ConnectedHumanoids = {}

local function connectHumanoid(plr, humanoid)

    if ConnectedHumanoids[humanoid] then
        return
    end

    ConnectedHumanoids[humanoid] = true

    humanoid.Died:Connect(function()

        createDeathNotification(plr)

    end)
end

local function monitorCharacter(plr, character)

    for _, obj in ipairs(character:GetChildren()) do

        if obj:IsA("Humanoid") then
            connectHumanoid(plr, obj)
        end
    end

    character.ChildAdded:Connect(function(obj)

        if obj:IsA("Humanoid") then
            connectHumanoid(plr, obj)
        end
    end)
end

---------------------------------------------------
-- PLAYER SETUP
---------------------------------------------------

local function setupPlayer(plr)

    if plr.Character then
        monitorCharacter(plr, plr.Character)
    end

    plr.CharacterAdded:Connect(function(character)

        task.wait(1)

        createRespawnNotification(plr)

        monitorCharacter(plr, character)

    end)
end

---------------------------------------------------
-- EXISTING PLAYERS
---------------------------------------------------

for _, plr in ipairs(Players:GetPlayers()) do
    setupPlayer(plr)
end

---------------------------------------------------
-- NEW PLAYERS
---------------------------------------------------

Players.PlayerAdded:Connect(function(plr)

    setupPlayer(plr)

end)
